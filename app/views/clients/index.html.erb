<h1 class="text-xl font-bold leading-tight tracking-tight md:text-2xl dark:text-white mb-4"><%= t('.title') %></h1>

<%= link_to t('.new_client'), new_client_path, class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 mb-3" %>

<div class="overflow-x-auto">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
          <%= Client.human_attribute_name(:name) %>
        </th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
          <%= Client.human_attribute_name(:due_day) %>
        </th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
          <%= Client.human_attribute_name(:payment_method_identifier) %>
        </th>
        <th scope="col" class="relative px-6 py-3">
          <span class="sr-only">Actions</span>
        </th>
      </tr>
    </thead>
    <tbody id="clients" class="bg-white divide-y divide-gray-200">
      <%= render @clients %>
    </tbody>

    <tfoot>
      <div>
        <div colspan="8" class="px-6 py-4 flex justify-end">
          <%= paginate @clients %>
        </div>
      </div>
    </tfoot>
  </table>
</div>