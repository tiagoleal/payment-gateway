<div class="bg-white shadow-md rounded-lg p-6">
  <%= form_with(model: client) do |form| %>
    <% if client.errors.any? %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative">
        <h2><%= t('errors.template.header', count: client.errors.count, model: Client.model_name.human) %>:</h2>

        <ul>
          <% client.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-3">
      <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :name, class: "mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
    </div>

    <div class="mb-3">
      <%= form.label :due_day, class: "block text-sm font-medium text-gray-700" %>
      <%= form.number_field :due_day, class: "mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
    </div>

    <div class="mb-3">
      <%= form.label :payment_method_identifier, class: "block text-sm font-medium text-gray-700" %>
      <%= form.select :payment_method_identifier, @payment_strategies, {}, class: "mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md" %>
    </div>

    <div class="mb-3">
      <%= form.submit t(client.persisted? ? 'helpers.submit.update' : 'helpers.submit.create', model: Client.model_name.human), class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
    </div>
  <% end %>
</div>

