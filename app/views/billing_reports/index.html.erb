<h1 class="text-2xl font-semibold mb-4"><%= t('.title') %></h1>

<div class="flex flex-wrap -mx-2">
  <div class="w-full md:w-1/2 px-2 mb-4">
    <div class="bg-white rounded-lg shadow-md overflow-hidden">
      <div class="bg-green-600 text-white p-4 flex justify-between items-center">
        <h2 class="font-bold text-lg"><%= t('.executed_billings_title') %></h2>
        <%= link_to t('.refresh_button'), billing_reports_index_path, class: "ml-4 inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-green-700 hover:bg-green-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
      </div>
      <div class="p-4">
        <% if @executed_billings.any? %>
          <div class="overflow-x-auto">
            <table class="min-w-full">
              <thead>
                <tr class="border-b">
                  <th class="text-left py-3 px-4 uppercase font-semibold text-sm"><%= t('activerecord.models.client') %></th>
                  <th class="text-left py-3 px-4 uppercase font-semibold text-sm"><%= t('activerecord.attributes.billing_record.payment_method_identifier') %></th>
                  <th class="text-left py-3 px-4 uppercase font-semibold text-sm"><%= t('activerecord.attributes.billing_record.billed_at') %></th>
                  <th class="text-left py-3 px-4 uppercase font-semibold text-sm"><%= t('activerecord.attributes.billing_record.status') %></th>
                </tr>
              </thead>
              <tbody class="text-gray-700">
                <% @executed_billings.each do |billing| %>
                  <tr class="border-b hover:bg-gray-100">
                    <td class="py-3 px-4"><%= billing.client.name %></td>
                    <td class="py-3 px-4"><%= t("payment_strategies.#{billing.payment_method_identifier}", default: billing.payment_method_identifier.humanize) %></td>
                    <td><%= billing.billed_at ? l(billing.billed_at, format: :short) : '' %></td>
                    <td class="py-3 px-4"><span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800"><%= t("billing_status.#{billing.status}", default: billing.status.humanize) %></span></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
          <div class="mt-4 flex justify-center">
            <%= paginate @executed_billings, param_name: :executed_billings_page %>
          </div>
        <% else %>
          <p class="text-gray-700"><%= t('.no_executed_billings') %></p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="w-full md:w-1/2 px-2 mb-4">
    <div class="bg-white rounded-lg shadow-md overflow-hidden">
      <div class="bg-sky-600 text-white p-4">
        <h2 class="font-bold text-lg"><%= t('.pending_billings_title') %></h2>
      </div>
      <div class="p-4">
        <% if @pending_clients_to_bill.any? %>
          <div class="overflow-x-auto">
            <table class="min-w-full">
              <thead>
                <tr class="border-b">
                  <th class="text-left py-3 px-4 uppercase font-semibold text-sm"><%= t('activerecord.models.client') %></th>
                  <th class="text-left py-3 px-4 uppercase font-semibold text-sm"><%= t('activerecord.attributes.client.payment_method_identifier') %></th>
                  <th class="text-left py-3 px-4 uppercase font-semibold text-sm"><%= t('.scheduled_execution_date') %></th>
                </tr>
              </thead>
              <tbody class="text-gray-700">
                <% @pending_clients_to_bill.each do |client| %>
                  <% # Calculate scheduled execution date %>
                  <% current_date = Time.zone.today %>
                  <% scheduled_date = Date.new(current_date.year, current_date.month, client.due_day) %>
                  <tr class="border-b hover:bg-gray-100">
                    <td class="py-3 px-4"><%= client.name %></td>
                    <td class="py-3 px-4"><%= t("payment_strategies.#{client.payment_method_identifier}", default: client.payment_method_identifier.humanize) %></td>
                    <td class="py-3 px-4"><%= scheduled_date ? l(scheduled_date, format: :short) : '' %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
          <div class="mt-4 flex justify-center">
            <%= paginate @pending_clients_to_bill, param_name: :pending_billings_page %>
          </div>
        <% else %>
          <p class="text-gray-700"><%= t('.no_pending_billings') %></p>
        <% end %>
      </div>
    </div>
  </div>
</div>
